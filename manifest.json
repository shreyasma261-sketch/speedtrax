{
  "name": "SpeedTrax \u2014 India's Vehicle Companion",
  "short_name": "SpeedTrax",
  "description": "Track speed, trips, fuel & expenses for Indian vehicles",
  "id": "/speedtrax/",
  "start_url": "/speedtrax/",
  "scope": "/speedtrax/",
  "display": "standalone",
  "display_override": [
    "tabbed",
    "window-controls-overlay",
    "standalone",
    "minimal-ui"
  ],
  "orientation": "portrait",
  "background_color": "#04040e",
  "theme_color": "#04040e",
  "lang": "en-IN",
  "dir": "ltr",
  "categories": [
    "navigation",
    "utilities",
    "travel"
  ],
  "prefer_related_applications": false,
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b2",
  "icons": [
    {
      "src": "https://shreyasma261-sketch.github.io/speedtrax/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "https://shreyasma261-sketch.github.io/speedtrax/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "https://shreyasma261-sketch.github.io/speedtrax/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "https://shreyasma261-sketch.github.io/speedtrax/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "https://shreyasma261-sketch.github.io/speedtrax/screenshots/narrow.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "SpeedTrax Speed Tracker"
    },
    {
      "src": "https://shreyasma261-sketch.github.io/speedtrax/screenshots/wide.png",
      "sizes": "1024x600",
      "type": "image/png",
      "form_factor": "wide",
      "label": "SpeedTrax Dashboard"
    }
  ],
  "shortcuts": [
    {
      "name": "Speed Tracker",
      "short_name": "Speed",
      "description": "Open the speed tracking screen",
      "url": "/speedtrax/?screen=speed"
    },
    {
      "name": "Trip Log",
      "short_name": "Trips",
      "description": "View your trip history",
      "url": "/speedtrax/?screen=trips"
    }
  ],
  "share_target": {
    "action": "/speedtrax/share",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "handle_links": "preferred",
  "scope_extensions": [
    {
      "origin": "https://shreyasma261-sketch.github.io"
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+speedtrax",
      "url": "/speedtrax/?protocol=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "/speedtrax/",
      "accept": {
        "application/json": [
          ".json"
        ],
        "text/plain": [
          ".txt"
        ]
      }
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=app.netlify.speedvehicletrax",
      "id": "app.netlify.speedvehicletrax"
    }
  ]
}
