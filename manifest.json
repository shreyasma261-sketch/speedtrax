{
  "name": "SpeedTrax — India's Vehicle Companion",
  "short_name": "SpeedTrax",
  "description": "Track speed, trips, fuel & expenses for Indian vehicles",
  "id": "/",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["tabbed", "window-controls-overlay", "standalone", "minimal-ui"],
  "orientation": "portrait",
  "background_color": "#04040e",
  "theme_color": "#04040e",
  "lang": "en-IN",
  "dir": "ltr",
  "categories": ["navigation", "utilities", "travel"],
  "prefer_related_applications": false,
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b2",
  "icons": [
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/narrow.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "SpeedTrax Speed Tracker"
    },
    {
      "src": "/screenshots/wide.png",
      "sizes": "1024x600",
      "type": "image/png",
      "form_factor": "wide",
      "label": "SpeedTrax Dashboard"
    }
  ],
  "shortcuts": [
    {
      "name": "Speed Tracker",
      "short_name": "Speed",
      "description": "Open the speed tracking screen",
      "url": "/?screen=speed",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Trip Log",
      "short_name": "Trips",
      "description": "View your trip history",
      "url": "/?screen=trips",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "GET",
    "params": { "title": "title", "text": "text", "url": "url" }
  },
  "launch_handler": { "client_mode": "focus-existing" },
  "handle_links": "preferred",
  "scope_extensions": [
    { "origin": "https://shreyasma261-sketch.github.io" }
  ],
  "protocol_handlers": [
    { "protocol": "web+speedtrax", "url": "/?protocol=%s" }
  ],
  "file_handlers": [
    {
      "action": "/",
      "accept": { "application/json": [".json"], "text/plain": [".txt"] }
    }
  ],
  "edge_side_panel": { "preferred_width": 400 },
  "widgets": [
    {
      "name": "SpeedTrax Widget",
      "description": "Quick speed and trip stats",
      "tag": "speedtrax-widget",
      "ms_ac_template": "/widget-template.json",
      "data": "/widget-data.json",
      "type": "application/json",
      "screenshots": [{ "src": "/screenshots/narrow.png", "sizes": "390x844", "label": "SpeedTrax Widget" }],
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192" }]
    }
  ],
  "note_taking": { "new_note_url": "/" },
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=app.netlify.speedvehicletrax",
      "id": "app.netlify.speedvehicletrax"
    }
  ]
}
