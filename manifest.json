{
  "name": "SpeedTrax — India's Vehicle Companion",
  "short_name": "SpeedTrax",
  "description": "Track speed, trips, fuel & expenses for Indian vehicles",
  "id": "/speedtrax/",
  "start_url": "/speedtrax/",
  "scope": "/speedtrax/",
  "display": "standalone",
  "display_override": ["tabbed", "window-controls-overlay", "standalone", "minimal-ui"],
  "orientation": "portrait",
  "background_color": "#04040e",
  "theme_color": "#04040e",
  "lang": "en-IN",
  "dir": "ltr",
  "categories": ["navigation", "utilities", "travel"],
  "prefer_related_applications": false,
  "icons": [
    { "src": "https://shreyasma261-sketch.github.io/speedtrax/icons/icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "https://shreyasma261-sketch.github.io/speedtrax/icons/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "https://shreyasma261-sketch.github.io/speedtrax/icons/icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "maskable" },
    { "src": "https://shreyasma261-sketch.github.io/speedtrax/icons/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
  ],
  "screenshots": [
    { "src": "https://shreyasma261-sketch.github.io/speedtrax/screenshots/narrow.png", "sizes": "390x844", "type": "image/png", "form_factor": "narrow", "label": "SpeedTrax Speed Tracker" },
    { "src": "https://shreyasma261-sketch.github.io/speedtrax/screenshots/wide.png", "sizes": "1024x600", "type": "image/png", "form_factor": "wide", "label": "SpeedTrax Dashboard" }
  ],
  "shortcuts": [
    { "name": "Speed Tracker", "short_name": "Speed", "url": "/speedtrax/?screen=speed" },
    { "name": "Trip Log", "short_name": "Trips", "url": "/speedtrax/?screen=trips" }
  ],
  "launch_handler": { "client_mode": "focus-existing" },
  "scope_extensions": [{ "origin": "https://shreyasma261-sketch.github.io" }],
  "related_applications": [
    { "platform": "play", "url": "https://play.google.com/store/apps/details?id=app.netlify.speedvehicletrax", "id": "app.netlify.speedvehicletrax" }
  ]
